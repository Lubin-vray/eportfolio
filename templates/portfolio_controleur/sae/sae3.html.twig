{% extends 'base.html.twig' %}

{% block stylesheets %}
<link id="theme" rel="stylesheet" href="{{ asset('css/style.css')}}">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
  /* ── Surcharges légères compatibles avec le thème Slate ── */

  /* Hero */
  .hero-sae {
    background: linear-gradient(135deg,,);
    border-bottom: 3px solid var(--bs-danger);
    padding: 60px 0 48px;
    position: relative;
    overflow: hidden;
  }

  .badge-sae {
    background: var(--bs-danger);
    color: #fff;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 14px;
  }
  .hero-imgs img {
    width: 100%;
    border-radius: 6px;
    object-fit: cover;
    box-shadow: 0 16px 40px rgba(0,0,0,.45);
  }
  .hero-imgs img:first-child { transform: rotate(-1.5deg) translateY(10px); }
  .hero-imgs img:last-child  { transform: rotate(1deg); }

  /* Labels de section */
  .section-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--bs-danger);
    margin-bottom: 8px;
    display: block;
  }

  /* Séparateur vertical */
  .sep-v {
    width: 1px;
    background: rgba(255,255,255,.1);
    align-self: stretch;
  }

  /* Bouton preuve */
  .btn-proof {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border: 1.5px solid rgba(255,255,255,.25);
    color: rgba(255,255,255,.8);
    border-radius: 4px;
    font-size: .84rem;
    font-weight: 500;
    text-decoration: none;
    transition: background .2s, border-color .2s, color .2s;
  }
  .btn-proof:hover {
    background: rgba(255,255,255,.1);
    border-color: rgba(255,255,255,.5);
    color: #fff;
  }

  /* ── Apprentissages critiques ── */
  .ac-section {
    background: var(--bs-gray-900);
  }

  .comp-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
  }
  .comp-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,.1);
  }
  .comp-num {
    background: var(--bs-danger);
    color: #fff;
    font-size: .65rem;
    font-weight: 800;
    padding: 3px 9px;
    border-radius: 2px;
    letter-spacing: .05em;
  }

  /* AC card */
  .ac-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 6px;
    padding: 20px 22px;
    height: 100%;
    position: relative;
    transition: background .2s, border-color .2s;
  }
  .ac-card:hover {
    background: rgba(255,255,255,.08);
    border-color: rgba(255,255,255,.18);
  }
  .ac-card .ac-code {
    font-size: .65rem;
    font-weight: 700;
    color: var(--bs-danger);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 7px;
  }
  .ac-card h5 {
    font-size: .9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 9px;
    line-height: 1.3;
    text-shadow: none;
  }
  .ac-card p {
    font-size: .81rem;
    color: rgba(255,255,255,.55);
    margin: 0;
    line-height: 1.65;
  }
  .ac-card .ac-bg-icon {
    position: absolute;
    top: 14px; right: 16px;
    font-size: 1.25rem;
    opacity: .15;
  }

  /* ── Analyse réflexive ── */
  .reflexive-section {
    background: var(--bs-container-bg);
    padding: 72px 0 80px;
  }

  .reflect-card {
    border-left: 3px solid var(--bs-danger);
    background: var(--bg-container-2);
    border-radius: 0 6px 6px 0;
    padding: 24px 26px;
    height: 100%;
    border-top: 1px solid rgba(0,0,0,.3);
    border-right: 1px solid rgba(0,0,0,.3);
    border-bottom: 1px solid rgba(0,0,0,.3);
  }
  .reflect-card .reflect-ico {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 12px;
  }
  .reflect-card h5 {
    font-size: .95rem;
    font-weight: 700;
    margin-bottom: 10px;
    text-shadow: none;
  }
  .reflect-card p {
    font-size: .84rem;
    line-height: 1.75;
    margin: 0;
    color: var(--bs-secondary-color);
  }

  /* Citation */
  .citation-block {
    background: var(--bg-container-2);
    border: 1px solid rgba(0,0,0,.35);
    border-radius: 6px;
    padding: 32px 36px;
    position: relative;
    overflow: hidden;
  }
  .citation-block blockquote {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.55;
    margin: 0 0 12px;
    color: #fff;
    text-shadow: none;
    position: relative;
  }
  .citation-block cite {
    font-size: .78rem;
    color: var(--bs-secondary-color);
    font-style: normal;
  }

  /* Pill point fort */
  .strength-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-container-2);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 100px;
    padding: 5px 14px;
    font-size: .79rem;
    font-weight: 500;
    color: rgba(255,255,255,.75);
  }

  @media (max-width: 768px) {
    .hero-imgs { display: none; }
    .sep-v { display: none; }
  }
</style>
{% endblock %}

{% block body %}
<div class="example-wrapper">
  <div class="container">
  <section class="hero-sae">
  <div class="container">
    <div class="row align-items-center gy-4">

      <div class="col-lg-7">
        <span class="badge-sae">SAÉ 1.03 · Semestre 1</span>
        <h1 class="mb-2 text-white text-start">
          Initiation aux télécommunications
        </h1>
        <p class="text-muted mb-0">BUT Réseaux &amp; Télécommunications &nbsp;·&nbsp; IUT &nbsp;·&nbsp; Travail en groupe</p>
      </div>

      <div class="col-lg-5">
        <div class="hero-imgs d-flex gap-2 justify-content-end">
          <img src="{{ asset('image/reseau1.jpg') }}" alt="Télécommunications">
          <img src="{{ asset('image/reseau2.jpg') }}" alt="Configuration réseau">
