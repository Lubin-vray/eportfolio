{% extends 'base.html.twig' %}

{% block stylesheets %}
<link id="theme" rel="stylesheet" href="{{ asset('css/style.css')}}">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
  /* ── Surcharges légères compatibles avec le thème Slate ── */

  /* Hero */
  .hero-sae {
    background: linear-gradient(135deg,,);
    border-bottom: 3px solid var(--bs-danger);
    padding: 60px 0 48px;
    position: relative;
    overflow: hidden;
  }

  .badge-sae {
    background: var(--bs-danger);
    color: #fff;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 14px;
  }
  .hero-imgs img {
    width: 100%;
    border-radius: 6px;
    object-fit: cover;
    box-shadow: 0 16px 40px rgba(0,0,0,.45);
  }
  .hero-imgs img:first-child { transform: rotate(-1.5deg) translateY(10px); }
  .hero-imgs img:last-child  { transform: rotate(1deg); }

  /* Labels de section */
  .section-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--bs-danger);
    margin-bottom: 8px;
    display: block;
  }

  /* Séparateur vertical */
  .sep-v {
    width: 1px;
    background: rgba(255,255,255,.1);
    align-self: stretch;
  }

  /* Bouton preuve */
  .btn-proof {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border: 1.5px solid rgba(255,255,255,.25);
    color: rgba(255,255,255,.8);
    border-radius: 4px;
    font-size: .84rem;
    font-weight: 500;
    text-decoration: none;
    transition: background .2s, border-color .2s, color .2s;
  }
  .btn-proof:hover {
    background: rgba(255,255,255,.1);
    border-color: rgba(255,255,255,.5);
    color: #fff;
  }

  /* ── Apprentissages critiques ── */
  .ac-section {
    background: var(--bs-gray-900);
  }

  .comp-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
  }
  .comp-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,.1);
  }
  .comp-num {
    background: var(--bs-danger);
    color: #fff;
    font-size: .65rem;
    font-weight: 800;
    padding: 3px 9px;
    border-radius: 2px;
    letter-spacing: .05em;
  }

  /* AC card */
  .ac-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 6px;
    padding: 20px 22px;
    height: 100%;
    position: relative;
    transition: background .2s, border-color .2s;
  }
  .ac-card:hover {
    background: rgba(255,255,255,.08);
    border-color: rgba(255,255,255,.18);
  }
  .ac-card .ac-code {
    font-size: .65rem;
    font-weight: 700;
    color: var(--bs-danger);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 7px;
  }
  .ac-card h5 {
    font-size: .9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 9px;
    line-height: 1.3;
    text-shadow: none;
  }
  .ac-card p {
    font-size: .81rem;
    color: rgba(255,255,255,.55);
    margin: 0;
    line-height: 1.65;
  }
  .ac-card .ac-bg-icon {
    position: absolute;
    top: 14px; right: 16px;
    font-size: 1.25rem;
    opacity: .15;
  }

  /* ── Analyse réflexive ── */
  .reflexive-section {
    background: var(--bs-container-bg);
    padding: 72px 0 80px;
  }

  .reflect-card {
    border-left: 3px solid var(--bs-danger);
    background: var(--bg-container-2);
    border-radius: 0 6px 6px 0;
    padding: 24px 26px;
    height: 100%;
    border-top: 1px solid rgba(0,0,0,.3);
    border-right: 1px solid rgba(0,0,0,.3);
    border-bottom: 1px solid rgba(0,0,0,.3);
  }
  .reflect-card .reflect-ico {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 12px;
  }
  .reflect-card h5 {
    font-size: .95rem;
    font-weight: 700;
    margin-bottom: 10px;
    text-shadow: none;
  }
  .reflect-card p {
    font-size: .84rem;
    line-height: 1.75;
    margin: 0;
    color: var(--bs-secondary-color);
  }

  /* Citation */
  .citation-block {
    background: var(--bg-container-2);
    border: 1px solid rgba(0,0,0,.35);
    border-radius: 6px;
    padding: 32px 36px;
    position: relative;
    overflow: hidden;
  }
  .citation-block blockquote {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.55;
    margin: 0 0 12px;
    color: #fff;
    text-shadow: none;
    position: relative;
  }
  .citation-block cite {
    font-size: .78rem;
    color: var(--bs-secondary-color);
    font-style: normal;
  }

  /* Pill point fort */
  .strength-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-container-2);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 100px;
    padding: 5px 14px;
    font-size: .79rem;
    font-weight: 500;
    color: rgba(255,255,255,.75);
  }

  @media (max-width: 768px) {
    .hero-imgs { display: none; }
    .sep-v { display: none; }
  }
</style>
{% endblock %}

{% block body %}
<div class="example-wrapper">
  <div class="container">
  <section class="hero-sae">
  <div class="container">
    <div class="row align-items-center gy-4">

      <div class="col-lg-7">
        <span class="badge-sae">SAÉ 1.03 · Semestre 1</span>
        <h1 class="mb-2 text-white text-start">
          Découvrir un dispositif de transmission
        </h1>
        <p class="text-muted mb-0">BUT Réseaux &amp; Télécommunications &nbsp;·&nbsp; IUT &nbsp;·&nbsp; Travail en groupe</p>
      </div>

      <div class="col-lg-5">
        <div class="hero-imgs d-flex gap-2 justify-content-end">
          <img src="{{ asset('image/reseau2.jpg') }}" alt="Configuration réseau">
        </div>
      </div>

    </div>
  </div>
  </section>


<!-- ════════════════════════════════════
     CONTEXTE / OBJECTIF / RÉALISATIONS
════════════════════════════════════ -->
<section class="py-5">
  <div class="container">
    <div class="row gy-4 align-items-start">

      <!-- Contexte -->
      <div class="col-md">
        <span class="section-label">Contexte</span>
        <h2 class="h4 text-start mb-3">Pourquoi cette SAÉ ?</h2>
        <p class="mb-0">
          Cette SAÉ permet de comprendre comment analyser, améliorer et valider une infrastructure réseau dans un environnement réel. Elle met en pratique les différentes étapes d’un projet technique, depuis l’identification des besoins jusqu’à la vérification finale des installations.
        </p>
      </div>

      <div class="sep-v d-none d-md-block"></div>

      <!-- Objectif -->
      <div class="col-md">
        <span class="section-label">Objectif</span>
        <h2 class="h4 text-start mb-3">Ce qu'on nous demande</h2>
        <p class="mb-0">
          Le travail s’organise autour de trois activités principales : réaliser un audit de couverture WiFi afin d’évaluer la qualité du réseau sans fil, produire un devis technique pour le renouvellement du matériel et l’aménagement d’une salle, puis effectuer des tests et le recettage du câblage afin de vérifier la conformité et la fiabilité des connexions réseau.
        </p>
      </div>

      <div class="sep-v d-none d-md-block"></div>

      <!-- Réalisations -->
      <div class="col-md">
        <span class="section-label">Réalisations</span>
        <h2 class="h4 text-start mb-3">Ce que j'ai produit</h2>
        <p class="mb-3">
          Audit de couverture WiFi avec AirCheck G2/NetAlly, devis pour la salle G007 (matériel Legrand),
          recettage du câblage cuivre avec Fluke Cable IQ, rapport technique et présentation de soutenance.
        </p>
        <div class="d-flex flex-column gap-2">
          <a href="{{ asset('portfolio/SAE1.03/rapport.docx') }}" target="_blank" class="btn-proof">
            <i class="bi bi-file-earmark-text"></i> Rapport technique détaillé
          </a>
          <a href="{{ asset('portfolio/SAE1.03/Présentation_soutenance_sae1.03.pdf') }}" target="_blank" class="btn-proof">
            <i class="bi bi-file-earmark-slides"></i> Présentation de soutenance
          </a>
          <a href="{{ asset('portfolio/SAE1.03/devis/Devis_finis.xlsx') }}" target="_blank" class="btn-proof">
            <i class="bi bi-file-earmark-spreadsheet"></i> Devis final salle G007
          </a>
          <a href="{{ asset('portfolio/SAE1.03/cuivre/cablage.xlsx') }}" target="_blank" class="btn-proof">
            <i class="bi bi-ethernet"></i> Fiche de test câblage cuivre
          </a>
          <a href="{{ asset('portfolio/SAE1.03/Audit_wifi/wifi.xlsx') }}" target="_blank" class="btn-proof">
            <i class="bi bi-wifi"></i> Mesures de l'audit WiFi
          </a>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ════════════════════════════════════
     APPRENTISSAGES CRITIQUES
════════════════════════════════════ -->
<section class="ac-section">
  <div class="container">

    <span class="section-label">Compétences du BUT R&amp;T</span>
    <h2 class="text-white text-start mb-5">Apprentissages critiques mobilisés</h2>

        <!-- ── C2 : Connecter ── -->
    <div class="mb-5">
      <div class="comp-header">
        <span class="comp-num">C2</span>
        Connecter les entreprises et les usagers
      </div>
      <div class="row g-3">

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-ethernet ac-bg-icon"></i>
            <div class="ac-code">AC12.01</div>
            <h5>Mesurer, analyser et commenter les signaux</h5>
            <p>L’utilisation du testeur CableIQ et les mesures de couverture WiFi m’ont permis d’analyser la qualité des liaisons réseau et des signaux sans fil. J’ai appris à interpréter les résultats obtenus afin d’identifier les pertes, perturbations ou zones de mauvaise couverture réseau.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-wifi ac-bg-icon"></i>
            <div class="ac-code">AC12.03</div>
            <h5>Déployer des supports de transmission</h5>
            <p>Les mesures de couverture WiFi avant et après installation m’ont aidé à comprendre l’impact de l’environnement sur le signal. J’ai identifié les sources d’atténuation et proposé des améliorations comme le repositionnement de bornes pour optimiser la couverture.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-wifi ac-bg-icon"></i>
            <div class="ac-code">AC12.05</div>
            <h5>Communiquer avec un tiers (client, collaborateur...) et adapter son discours et sa langue à son interlocuteur</h5>
            <p>J’ai appris à adapter mon discours selon l’interlocuteur, en simplifiant les explications pour un public non technique et en utilisant un vocabulaire plus précis avec les profils techniques. Cela a facilité la compréhension des besoins et des solutions.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════
     ANALYSE RÉFLEXIVE
════════════════════════════════════ -->
<section class="reflexive-section">
  <div class="container">

    <span class="section-label">Recul &amp; apprentissage</span>
    <h2 class="text-start mb-2">Analyse réflexive</h2>
    <p class="mb-5" style="max-width:680px; color: var(--bs-secondary-color); font-size:.95rem;">
      Au-delà de la simple exécution de la SAÉ, voici comment ce projet terrain a changé ma façon
      d'aborder une infrastructure réseau et de travailler en équipe dans un contexte professionnel réel.
    </p>

    <div class="row g-4 mb-4">

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🔍</span>
          <h5>Ce que j'ai vraiment appris</h5>
          <p>L’utilisation d’outils comme l’AirCheck G2 ou le Fluke CableIQ m’a permis de mieux comprendre comment évaluer la qualité d’un réseau, aussi bien en WiFi qu’en câblage. Ces manipulations concrètes m’ont aidé à relier les notions vues en cours à des situations réelles et à comprendre qu’un réseau doit être testé et vérifié pour garantir son bon fonctionnement.</p>        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">⚠️</span>
          <h5>Les difficultés rencontrées</h5>
          <p>La coordination entre les trois volets (audit, devis, recettage) a été la principale difficulté. Les mesures WiFi dépendaient de l’accès aux salles, tandis que la réalisation du devis demandait de choisir des équipements adaptés aux besoins. Organiser ces différentes tâches sans bloquer l’avancement du projet a nécessité une bonne communication et une gestion rigoureuse du travail.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🚀</span>
          <h5>Ce que je ferais différemment</h5>
          <p>J’aurais pris davantage de temps pour analyser et exploiter les mesures WiFi réalisées sur les points fixes. Cela aurait permis d’interpréter plus précisément les différences observées avant et après les travaux et de rendre notre présentation finale plus complète.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🔗</span>
          <h5>Lien avec la formation R&amp;T</h5>
          <p>Cette SAÉ est celle qui ressemble le plus à une mission en entreprise : un client (l'IUT), un besoin réel, des contraintes budgétaires et un livrable attendu. Elle prépare directement aux stages et aux projets professionnels du semestre 3, où l'on retrouvera ces mêmes phases d'audit, de chiffrage et de validation.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🎯</span>
          <h5>Compétences transférables</h5>
          <p>Savoir rédiger un devis argumenté, certifier une infrastructure et présenter des résultats techniques à un jury non-expert sont des compétences directement valorisables en entretien. Ce projet m'a donné des réalisations concrètes à mentionner, là où d'autres n'ont que des notions théoriques à montrer.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">📈</span>
          <h5>Progression personnelle</h5>
          <p>J'ai développé une vision systémique de l'infrastructure réseau : un réseau ne se résume pas à ses équipements actifs, il repose sur une couche passive (câblage, connectique, armoires) dont la qualité conditionne tout le reste. Cette conscience du "support physique" change durablement la façon d'aborder un projet réseau.</p>
        </div>
      </div>

    </div>

 
    <!-- Points forts -->
    <span class="section-label mb-3 d-block">Points forts acquis en synthèse</span>
    <div class="d-flex flex-wrap gap-2">
      <span class="strength-pill"><i class="bi bi-wifi"></i> Audit WiFi</span>
      <span class="strength-pill"><i class="bi bi-ethernet"></i> Câblage cuivre & recettage</span>
      <span class="strength-pill"><i class="bi bi-receipt"></i> Rédaction de devis</span>
      <span class="strength-pill"><i class="bi bi-tools"></i> Outils professionnels</span>
      <span class="strength-pill"><i class="bi bi-people"></i> Travail collaboratif</span>
      <span class="strength-pill"><i class="bi bi-graph-up"></i> Démarche qualité</span>
      <span class="strength-pill"><i class="bi bi-kanban"></i> Gestion de projet</span>
      <span class="strength-pill"><i class="bi bi-mic"></i> Soutenance technique</span>
    </div>

  </div>
</div>
</section>


</div>
<br><br>

{% endblock %}