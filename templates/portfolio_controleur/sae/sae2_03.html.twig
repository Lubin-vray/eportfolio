{% block body %}
<div class="example-wrapper">
  <div class="container">
  <section class="hero-sae">
  <div class="container">
    <div class="row align-items-center gy-4">

      <div class="col-lg-7">
        <span class="badge-sae">SAÉ 2.03 · Semestre 2</span>
        <h1 class="mb-2 text-white text-start">
          Mettre en place une solution informatique pour l'entreprise
        </h1>
        <p class="text-muted mb-0">BUT Réseaux &amp; Télécommunications &nbsp;·&nbsp; IUT &nbsp;·&nbsp; Semestre 2</p>
      </div>

      <div class="col-lg-5">
        <div class="hero-imgs d-flex gap-2 justify-content-end">
          <img src="{{ asset('image/competence.png') }}" alt="Docker et conteneurs">
          <img src="{{ asset('image/prog.png') }}" alt="WordPress et base de données">
