{% extends 'base.html.twig' %}

{% block stylesheets %}
<link id="theme" rel="stylesheet" href="{{ asset('css/style.css')}}">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
  /* ── Surcharges légères compatibles avec le thème Slate ── */

  /* Hero */
  .hero-sae {
    background: linear-gradient(135deg,,);
    border-bottom: 3px solid var(--bs-danger);
    padding: 60px 0 48px;
    position: relative;
    overflow: hidden;
  }

  .badge-sae {
    background: var(--bs-danger);
    color: #fff;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 14px;
  }
  .hero-imgs img {
    width:100%;
    border-radius: 6px;
    object-fit: cover;
    box-shadow: 0 16px 40px rgba(0,0,0,.45);
  }
  .hero-imgs img:first-child { transform: rotate(-1.5deg) translateY(10px); }
  .hero-imgs img:last-child  { transform: rotate(1deg); }

  /* Labels de section */
  .section-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--bs-danger);
    margin-bottom: 8px;
    display: block;
  }

  /* Séparateur vertical */
  .sep-v {
    width: 1px;
    background: rgba(255,255,255,.1);
    align-self: stretch;
  }

  /* Bouton preuve */
  .btn-proof {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border: 1.5px solid rgba(255,255,255,.25);
    color: rgba(255,255,255,.8);
    border-radius: 4px;
    font-size: .84rem;
    font-weight: 500;
    text-decoration: none;
    transition: background .2s, border-color .2s, color .2s;
  }
  .btn-proof:hover {
    background: rgba(255,255,255,.1);
    border-color: rgba(255,255,255,.5);
    color: #fff;
  }

  /* ── Apprentissages critiques ── */
  .ac-section {
    background: var(--bs-gray-900);
  }

  .comp-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
  }
  .comp-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,.1);
  }
  .comp-num {
    background: var(--bs-danger);
    color: #fff;
    font-size: .65rem;
    font-weight: 800;
    padding: 3px 9px;
    border-radius: 2px;
    letter-spacing: .05em;
  }

  /* AC card */
  .ac-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 6px;
    padding: 20px 22px;
    height: 100%;
    position: relative;
    transition: background .2s, border-color .2s;
  }
  .ac-card:hover {
    background: rgba(255,255,255,.08);
    border-color: rgba(255,255,255,.18);
  }
  .ac-card .ac-code {
    font-size: .65rem;
    font-weight: 700;
    color: var(--bs-danger);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 7px;
  }
  .ac-card h5 {
    font-size: .9rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 9px;
    line-height: 1.3;
    text-shadow: none;
  }
  .ac-card p {
    font-size: .81rem;
    color: rgba(255,255,255,.55);
    margin: 0;
    line-height: 1.65;
  }
  .ac-card .ac-bg-icon {
    position: absolute;
    top: 14px; right: 16px;
    font-size: 1.25rem;
    opacity: .15;
  }

  /* ── Analyse réflexive ── */
  .reflexive-section {
    background: var(--bs-container-bg);
    padding: 72px 0 80px;
  }

  .reflect-card {
    border-left: 3px solid var(--bs-danger);
    background: var(--bg-container-2);
    border-radius: 0 6px 6px 0;
    padding: 24px 26px;
    height: 100%;
    border-top: 1px solid rgba(0,0,0,.3);
    border-right: 1px solid rgba(0,0,0,.3);
    border-bottom: 1px solid rgba(0,0,0,.3);
  }
  .reflect-card .reflect-ico {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 12px;
  }
  .reflect-card h5 {
    font-size: .95rem;
    font-weight: 700;
    margin-bottom: 10px;
    text-shadow: none;
  }
  .reflect-card p {
    font-size: .84rem;
    line-height: 1.75;
    margin: 0;
    color: var(--bs-secondary-color);
  }

  /* Citation */
  .citation-block {
    background: var(--bg-container-2);
    border: 1px solid rgba(0,0,0,.35);
    border-radius: 6px;
    padding: 32px 36px;
    position: relative;
    overflow: hidden;
  }

  .citation-block blockquote {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.55;
    margin: 0 0 12px;
    color: #fff;
    text-shadow: none;
    position: relative;
  }
  .citation-block cite {
    font-size: .78rem;
    color: var(--bs-secondary-color);
    font-style: normal;
  }

  /* Pill point fort */
  .strength-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-container-2);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 100px;
    padding: 5px 14px;
    font-size: .79rem;
    font-weight: 500;
    color: rgba(255,255,255,.75);
  }

  @media (max-width: 768px) {
    .hero-imgs { display: none; }
    .sep-v { display: none; }
  }
</style>
{% endblock %}

{% block body %}
<div class="example-wrapper">
  <div class="container">
  <section class="hero-sae">
  <div class="container">
    <div class="row align-items-center gy-4">

      <div class="col-lg-7">
        <span class="badge-sae">SAÉ 1.04 · Semestre 1</span>
        <h1 class="mb-2 text-white text-start">
          Se présenter sur internet
        </h1>
        <p class="text-muted mb-0">BUT Réseaux &amp; Télécommunications &nbsp;·&nbsp; IUT &nbsp;·&nbsp; Semestre 1</p>
      </div>

      <div class="col-lg-5">
        <div class="hero-imgs d-flex gap-2 justify-content-end">
          <img src="{{ asset('image/competence.png') }}" alt="Compétences">
          <img src="{{ asset('image/prog.png') }}" alt="Programmation">
        </div>
      </div>

    </div>
  </div>
  </section>


<!-- ════════════════════════════════════
     CONTEXTE / OBJECTIF / RÉALISATIONS
════════════════════════════════════ -->
<section class="py-5">
  <div class="container">
    <div class="row gy-4 align-items-start">

      <!-- Contexte -->
      <div class="col-md">
        <span class="section-label">Contexte</span>
        <h2 class="h4 text-start mb-3">Pourquoi cette SAÉ ?</h2>
        <p class="mb-0">
          Cette SAÉ nous a amenés à réfléchir à notre avenir professionnel en BUT Réseaux et Télécommunications,
          en nous incitant à créer un site web personnel regroupant notre portfolio, notre CV et des informations
          clés pour nous présenter sur internet.
        </p>
      </div>

      <div class="sep-v d-none d-md-block"></div>

      <!-- Objectif -->
      <div class="col-md">
        <span class="section-label">Objectif</span>
        <h2 class="h4 text-start mb-3">Ce qu'on nous demande</h2>
        <p class="mb-0">
          Mettre en avant nos points forts et nos compétences tout en construisant une vitrine professionnelle
          en ligne. L'objectif à terme est d'impressionner les recruteurs pour décrocher une alternance ou un
          stage grâce à un profil en ligne soigné et valorisant.
        </p>
      </div>

      <div class="sep-v d-none d-md-block"></div>

      <!-- Réalisations -->
      <div class="col-md">
        <span class="section-label">Réalisations</span>
        <h2 class="h4 text-start mb-3">Ce que j'ai produit</h2>
        <p class="mb-3">
          Création d'un site web personnel présentant mon portfolio, mon CV et mes informations clés,
          conçu en HTML/CSS et hébergé via GitHub Pages.
        </p>
        <div class="d-flex flex-column gap-2">
          <a href="https://github.com/Lubin-vray/eportfolio.git" target="_blank" class="btn-proof">
            <i class="bi bi-github"></i> Dépôt GitHub du site
          </a>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ════════════════════════════════════
     APPRENTISSAGES CRITIQUES
════════════════════════════════════ -->
<section class="ac-section py-5">
  <div class="container">

    <span class="section-label">Compétences du BUT R&amp;T</span>
    <h2 class="text-white text-start mb-5">Apprentissages critiques mobilisés</h2>

    <!-- ── C5 : Sensibiliser / Communiquer ── -->
    <div class="mb-5">
      <div class="comp-header">
        <span class="comp-num">C5</span>
        Sensibiliser et former les acteurs
      </div>
      <div class="row g-3">

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-person-badge ac-bg-icon"></i>
            <div class="ac-code">AC15.01</div>
            <h5>Communiquer sur son profil professionnel</h5>
            <p>La création du site m'a obligé à formaliser et structurer mon identité professionnelle, en choisissant les informations pertinentes à mettre en avant pour un recruteur.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-file-earmark-person ac-bg-icon"></i>
            <div class="ac-code">AC15.02</div>
            <h5>Produire des ressources de présentation</h5>
            <p>Rédaction et mise en page d'un CV en ligne et d'un portfolio structuré, conçus pour être lisibles, attractifs et réutilisables dans différents contextes professionnels.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-globe ac-bg-icon"></i>
            <div class="ac-code">AC15.03</div>
            <h5>S'approprier les outils du web</h5>
            <p>Utilisation de HTML, CSS et GitHub Pages pour concevoir, publier et maintenir un site web fonctionnel, avec une démarche autonome de prise en main des outils.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- ── C6 : Travailler en autonomie ── -->
    <div class="mb-5">
      <div class="comp-header">
        <span class="comp-num">C6</span>
        Travailler en autonomie et s'intégrer dans une équipe
      </div>
      <div class="row g-3">

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-kanban ac-bg-icon"></i>
            <div class="ac-code">AC16.01</div>
            <h5>Gérer un projet en autonomie</h5>
            <p>Ce projet individuel m'a demandé d'organiser mon travail de façon autonome : définir les priorités, structurer le contenu et respecter les délais sans encadrement constant.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-git ac-bg-icon"></i>
            <div class="ac-code">AC16.02</div>
            <h5>Utiliser un outil de versionnage</h5>
            <p>Hébergement et gestion du site via Git et GitHub, introduisant les bonnes pratiques de versionnage dès le premier semestre de la formation.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- ── C4 : Développer ── -->
    <div>
      <div class="comp-header">
        <span class="comp-num">C4</span>
        Développer des applications informatiques
      </div>
      <div class="row g-3">

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-code-slash ac-bg-icon"></i>
            <div class="ac-code">AC14.01</div>
            <h5>Développer une interface web</h5>
            <p>Conception et intégration d'une interface web en HTML/CSS, en veillant à la lisibilité, la structure sémantique et la compatibilité avec les navigateurs courants.</p>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="ac-card">
            <i class="bi bi-phone ac-bg-icon"></i>
            <div class="ac-code">AC14.02</div>
            <h5>Adapter le rendu à différents supports</h5>
            <p>Prise en compte du responsive design pour que le site soit consultable aussi bien sur ordinateur que sur mobile, répondant aux attentes actuelles des recruteurs.</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>


<!-- ════════════════════════════════════
     ANALYSE RÉFLEXIVE
════════════════════════════════════ -->
<section class="reflexive-section">
  <div class="container">

    <span class="section-label">Recul &amp; apprentissage</span>
    <h2 class="text-start mb-2">Analyse réflexive</h2>
    <p class="mb-5" style="max-width:680px; color: var(--bs-secondary-color); font-size:.95rem;">
      Au-delà de la simple création d'un site, voici comment ce projet a façonné ma façon d'aborder
      ma présence professionnelle en ligne et mon rapport à l'outil informatique.
    </p>

    <div class="row g-4 mb-4">

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🔍</span>
          <h5>Ce que j'ai vraiment appris</h5>
          <p>Avant cette SAÉ, je n'avais jamais réfléchi à ma présentation professionnelle en ligne. Construire ce site m'a forcé à prendre du recul sur mes compétences, à les formaliser et à comprendre ce qu'un recruteur cherche réellement. La technique HTML/CSS était secondaire : le vrai défi était de se vendre avec clarté et honnêteté.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">⚠️</span>
          <h5>Les difficultés rencontrées</h5>
          <p>La principale difficulté a été de trouver le bon équilibre entre sobriété et attractivité visuelle. Trop chargé, le site perd en lisibilité ; trop vide, il ne retient pas l'attention. J'ai dû itérer plusieurs fois sur la mise en page et le contenu pour trouver un rendu à la fois professionnel et personnel.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🚀</span>
          <h5>Ce que je ferais différemment</h5>
          <p>J'aurais intégré du JavaScript dès le départ pour rendre le site plus interactif — animations légères, filtres sur les projets — et j'aurais utilisé un framework CSS comme Tailwind pour gagner en cohérence et en rapidité de développement.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🔗</span>
          <h5>Lien avec la formation R&amp;T</h5>
          <p>Ce projet illustre parfaitement l'idée que les compétences techniques seules ne suffisent pas : savoir se présenter, communiquer et valoriser son profil est aussi important que de maîtriser un protocole réseau. Ce site évoluera au fil des semestres pour refléter ma progression.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">🎯</span>
          <h5>Compétences transférables</h5>
          <p>Savoir structurer un discours sur soi-même, utiliser Git pour gérer un projet, et publier un livrable en ligne sont des compétences directement mobilisables en stage, en alternance et dans la vie professionnelle. Ce ne sont pas des compétences anecdotiques.</p>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="reflect-card">
          <span class="reflect-ico">📈</span>
          <h5>Progression personnelle</h5>
          <p>Ce projet m'a donné le réflexe de documenter et de rendre visible ce que je produis. Depuis, je pousse systématiquement mes projets sur GitHub et je mets à jour mon portfolio régulièrement — une habitude que je compte maintenir tout au long de mes études.</p>
        </div>
      </div>

    </div>

    <!-- Citation -->
    <div class="row mt-2 mb-5">
      <div class="col-lg-8 offset-lg-2">
        <div class="citation-block">
          <blockquote>
            "Se présenter sur internet, ce n'est pas juste créer un site —
            c'est apprendre à se connaître assez pour expliquer aux autres qui on est
            et ce qu'on veut devenir."
          </blockquote>
          <cite>— Réflexion personnelle à l'issue de la SAÉ 1.04</cite>
        </div>
      </div>
    </div>

    <!-- Points forts -->
    <span class="section-label mb-3 d-block">Points forts acquis en synthèse</span>
    <div class="d-flex flex-wrap gap-2">
      <span class="strength-pill"><i class="bi bi-person-check"></i> Autonomie</span>
      <span class="strength-pill"><i class="bi bi-code-slash"></i> HTML / CSS</span>
      <span class="strength-pill"><i class="bi bi-git"></i> Git &amp; GitHub</span>
      <span class="strength-pill"><i class="bi bi-layout-text-window"></i> Mise en page web</span>
      <span class="strength-pill"><i class="bi bi-person-lines-fill"></i> Communication professionnelle</span>
      <span class="strength-pill"><i class="bi bi-phone"></i> Responsive design</span>
      <span class="strength-pill"><i class="bi bi-briefcase"></i> Vision recrutement</span>
      <span class="strength-pill"><i class="bi bi-arrow-repeat"></i> Itération &amp; amélioration continue</span>
    </div>

  </div>
</div>
</section>

<br><br>

  </div>
</div>
{% endblock %}
